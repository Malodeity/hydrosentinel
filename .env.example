# Copy this file to .env before starting the project.

# PostgreSQL database used by the FastAPI backend.
POSTGRES_DB=hydrosentinel
POSTGRES_USER=malo
POSTGRES_PASSWORD=Unlimitedphos@1
POSTGRES_PORT=5433

# SQLAlchemy connection string consumed by the backend service.
DATABASE_URL=postgresql://malo:Unlimitedphos%401@localhost:5433/hydrosentinel

# FastAPI application settings.
PROJECT_NAME=HydroSentinel API
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# JWT authentication settings.
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Initial admin account seeded on backend startup.
ADMIN_EMAIL=admin@hydrosentinel.co.za
ADMIN_PASSWORD=admin123
# Optional: if you already have a pre-hashed password from SQL setup, set it here.
ADMIN_PASSWORD_HASH=

# Offline-trained XGBoost model location.
MODEL_PATH=/app/backend/ai/model.pkl

# Anthropic API key used for AI summaries, recommendations, and cached digest generation.
ANTHROPIC_API_KEY=your-key-here

# Frontend environment variables passed to Vite.
VITE_API_URL=http://localhost:8000
